# Development Containerfile for the MSN Weather FastAPI service
FROM python:3.12-slim-trixie@sha256:fa48eefe2146644c2308b909d6bb7651a768178f84fc9550dcd495e4d6d84d01

WORKDIR /app

# Install system dependencies including development tools
RUN apt-get update && apt-get install -y \
    gcc \
    curl \
    git \
    vim \
    && rm -rf /var/lib/apt/lists/*

# Copy Python project files
COPY pyproject.toml .
COPY README.md .

RUN python -m pip install --no-cache-dir --upgrade pip

# Install Python dependencies including dev dependencies
RUN python -m pip install --no-cache-dir -e ".[dev]"

# Install additional development tools
RUN python -m pip install --no-cache-dir \
    ipython \
    ipdb \
    pytest-watch \
    geopy

# Copy source code (will be overridden by volume in compose)
COPY backend/ backend/
COPY api.py .
COPY tests/ tests/

# Ensure package is installed in editable mode
RUN python -m pip install -e .

# Expose API port
EXPOSE 5000

# Set environment variables for development
ENV APP_ENV=development
ENV APP_DEBUG=1
ENV PYTHONUNBUFFERED=1

# Default command (can be overridden in compose)
CMD ["python", "api.py"]
